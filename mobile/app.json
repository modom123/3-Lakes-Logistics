{
  "expo": {
    "name": "3 Lakes Driver",
    "slug": "3-lakes-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.threelakeslogistics.driver"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1565C0"
      },
      "package": "com.threelakeslogistics.driver",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1565C0",
          "defaultChannel": "dispatch"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow 3 Lakes Driver to use your location for pickup and delivery confirmation."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow 3 Lakes Driver to access your photos for document uploads.",
          "cameraPermission": "Allow 3 Lakes Driver to use your camera to photograph BOL, POD, and receipts."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3-lakes-driver"
      }
    }
  }
}
