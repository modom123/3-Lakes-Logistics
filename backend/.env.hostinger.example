# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HOSTINGER IMAP CONFIGURATION — Internal Email Ingestion
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable/disable IMAP polling
HOSTINGER_IMAP_ENABLED=true

# IMAP server details (Hostinger standard)
HOSTINGER_IMAP_HOST=imap.hostinger.com
HOSTINGER_IMAP_PORT=993

# Email account credentials from Hostinger control panel
# Use your full email address as username
HOSTINGER_IMAP_USERNAME=orders@yourdomain.com
HOSTINGER_IMAP_PASSWORD=your_email_password_here

# Poll interval in seconds (default: 300 = 5 minutes)
# Lower = faster processing, higher CPU
# Higher = slower processing, lower CPU
HOSTINGER_IMAP_POLL_INTERVAL_SECONDS=300

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SENDGRID CONFIGURATION — Broker Email Ingestion (Existing)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# SendGrid API key for inbound email parsing
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inbound email address (webhook receives emails to this)
SENDGRID_INBOUND_EMAIL=loads@3lakes.logistics

# Optional: webhook signature verification key
# Get from SendGrid dashboard → Settings → Inbound Parse
SENDGRID_INBOUND_SECRET=xxxxxxxxxxxxxxxxxxxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.hostinger
# 2. Replace your-domain.com with your actual domain
# 3. Get credentials from Hostinger control panel:
#    - Email: your full email address (e.g., orders@yourdomain.com)
#    - Password: the email account password
# 4. Merge values into your main .env file
# 5. Restart the API: uvicorn app.main:app --reload
# 6. Test IMAP polling: curl -X POST http://localhost:8080/api/email/imap/poll

# SECURITY WARNING:
# Never commit .env to version control!
# Add to .gitignore: .env, .env.local, .env.*.local
