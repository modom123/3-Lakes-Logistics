# ============================================================
# 3 Lakes Logistics — backend environment variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Supabase (Master Hub) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_FOUNDERS=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_SCALE=price_...

# --- Twilio (800-number + SMS) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+18005551234

# --- Vapi.ai (outbound voice — Vance) ---
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_ASSISTANT_ID_VANCE=
VAPI_PHONE_NUMBER_ID=

# --- ElevenLabs (TTS fallback) ---
ELEVENLABS_API_KEY=

# --- Email (Resend preferred, Postmark fallback, SES opt) ---
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=ops@3lakeslogistics.com
SES_REGION=us-east-1

# --- FMCSA SAFER / CSA API (Shield) ---
FMCSA_WEBKEY=

# --- Google APIs (Vision OCR, Maps) ---
GOOGLE_MAPS_API_KEY=
GOOGLE_VISION_CREDENTIALS_JSON=/path/to/service-account.json

# --- ELD integrations (Motive primary) ---
MOTIVE_API_KEY=
MOTIVE_WEBHOOK_SECRET=
SAMSARA_API_KEY=
GEOTAB_USERNAME=
GEOTAB_PASSWORD=
GEOTAB_DATABASE=
OMNITRACS_API_KEY=

# --- Airtable (legacy lead sync) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# --- Slack ops channels ---
SLACK_WEBHOOK_OPS=
SLACK_WEBHOOK_ALERTS=

# --- Security ---
PII_ENCRYPTION_KEY=generate-32byte-random-string
RETENTION_DAYS_LEADS=730
RETENTION_DAYS_WEBHOOKS=180

# --- Observability ---
SENTRY_DSN=

# --- Queue + Scheduler ---
QUEUE_POLL_INTERVAL_SEC=5
QUEUE_MAX_CONCURRENCY=4
ENABLE_SCHEDULER=0

# --- App ---
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,https://3lakeslogistics.com
API_BEARER_TOKEN=change-me-in-prod
