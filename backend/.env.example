# ============================================================
# 3 Lakes Logistics — backend environment variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Supabase (Master Hub) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ($200/mo Founders subscription) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_FOUNDERS=price_...

# --- Twilio (SMS + voice comms) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+13135469006

# --- Vapi.ai (outbound voice — Vance) ---
VAPI_API_KEY=
VAPI_ASSISTANT_ID_VANCE=
VAPI_PHONE_NUMBER_ID=

# --- Bland AI (outbound prospecting calls — Vance, cheaper than Vapi) ---
# Sign up at bland.ai, get API key from dashboard
# Organization ID tracks calls in your Bland account
BLAND_AI_API_KEY=
BLAND_AI_WEBHOOK_SECRET=
BLAND_AI_ORG_ID=org_73437d593e2eb4d277d801b2d5296474b55e8f35df786fd0d3471ba6376c51713d5bd1fcd3ea21da6f7969

# --- ElevenLabs (TTS fallback) ---
ELEVENLABS_API_KEY=

# --- Postmark / SendGrid (transactional email — Nexus + Email Ingest) ---
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=ops@3lakeslogistics.com
SENDGRID_API_KEY=
SENDGRID_INBOUND_EMAIL=loads@3lakes.logistics
SENDGRID_INBOUND_SECRET=

# --- FMCSA SAFER / CSA API (Shield) ---
FMCSA_WEBKEY=

# --- Google APIs (Vision OCR for Scout, Maps for prospecting) ---
GOOGLE_MAPS_API_KEY=
GOOGLE_VISION_CREDENTIALS_JSON=/path/to/service-account.json

# --- ELD integrations (Motive primary) ---
MOTIVE_API_KEY=
SAMSARA_API_KEY=
GEOTAB_USERNAME=
GEOTAB_PASSWORD=
OMNITRACS_API_KEY=

# --- Airtable (Carrier Leads migration) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appyRkym1i9mXEnzP

# --- Adobe Sign (e-signature integration) ---
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
ADOBE_ACCOUNT_ID=
ADOBE_API_ENDPOINT=https://api.na1.adobesign.com

# --- Sentry (error tracking) ---
SENTRY_DSN=

# --- Load Board APIs (Sonny — daily load sourcing) ---
# DAT Freight — developer.dat.com (OAuth2 client credentials)
DAT_CLIENT_ID=
DAT_CLIENT_SECRET=

# Truckstop — developer.truckstop.com (requires signed SIA)
TRUCKSTOP_USERNAME=
TRUCKSTOP_PASSWORD=
TRUCKSTOP_PARTNER_ID=

# 123Loadboard — 123loadboard.com/api/ (REST API key)
LOADBOARD_123_API_KEY=

# Trucker Path — docs.truckerpath.com (API key)
TRUCKERPATH_API_KEY=

# Direct Freight — apidocs.directfreight.com (username/password)
DIRECT_FREIGHT_USERNAME=
DIRECT_FREIGHT_PASSWORD=

# Uber Freight — developer.uberfreight.com (OAuth2)
UBER_FREIGHT_CLIENT_ID=
UBER_FREIGHT_CLIENT_SECRET=

# Loadsmart — developer.loadsmart.com (API key)
LOADSMART_API_KEY=

# NewTrul (acquired by Highway) — API key
NEWTRUL_API_KEY=

# Flock Freight — API/EDI integration key
FLOCK_FREIGHT_API_KEY=

# J.B. Hunt 360 — developer.jbhunt.com (OAuth2)
JBHUNT_CLIENT_ID=
JBHUNT_CLIENT_SECRET=

# Coyote GO (RXO) — api.coyote.com (OAuth2)
COYOTE_CLIENT_ID=
COYOTE_CLIENT_SECRET=

# Arrive Logistics — developer.arrive.com (OAuth2)
ARRIVE_CLIENT_ID=
ARRIVE_CLIENT_SECRET=

# Echo Global (EchoSync) — echo.com/technology/integrations/echosync/
ECHO_GLOBAL_API_KEY=

# Cargo Chief — cargochief.com (API key)
CARGO_CHIEF_API_KEY=

# --- App ---
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,https://3lakeslogistics.com
API_BEARER_TOKEN=change-me-in-prod
