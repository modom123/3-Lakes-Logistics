# ============================================================
# 3 Lakes Logistics — backend environment variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Supabase (Master Hub) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ($200/mo Founders subscription) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_FOUNDERS=price_...

# --- Twilio (800-number + SMS) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+18005551234

# --- Vapi.ai (outbound voice — Vance) ---
VAPI_API_KEY=
VAPI_ASSISTANT_ID_VANCE=
VAPI_PHONE_NUMBER_ID=

# --- ElevenLabs (TTS fallback) ---
ELEVENLABS_API_KEY=

# --- Postmark / SendGrid (transactional email — Nexus) ---
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=ops@3lakeslogistics.com

# --- FMCSA SAFER / CSA API (Shield) ---
FMCSA_WEBKEY=

# --- Google APIs (Vision OCR for Scout, Maps for prospecting) ---
GOOGLE_MAPS_API_KEY=
GOOGLE_VISION_CREDENTIALS_JSON=/path/to/service-account.json

# --- ELD integrations (Motive primary) ---
MOTIVE_API_KEY=
SAMSARA_API_KEY=
GEOTAB_USERNAME=
GEOTAB_PASSWORD=
OMNITRACS_API_KEY=

# --- Airtable (legacy lead sync) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# --- Sentry (error tracking) ---
SENTRY_DSN=

# --- App ---
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,https://3lakeslogistics.com
API_BEARER_TOKEN=change-me-in-prod
